{
    "name": "@fremtind/jokul",
    "version": "5.0.0-next.6",
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "description": "Jøkul monopakke",
    "homepage": "https://github.com/fremtind/jokul/tree/main/packages/jokul",
    "keywords": [],
    "license": "MIT",
    "sideEffects": ["*.css", "*.scss"],
    "files": [
        "./bin",
        "./build",
        "./codemods",
        "./styles",
        "./src/fonts",
        "./package.json"
    ],
    "bin": {
        "jokul": "./bin/jokul.mjs"
    },
    "exports": {
        "./package.json": "./package.json",
        "./styles/jkl": "./styles/jkl/_index.scss",
        "./styles/*": "./styles/*",
        "./tailwind": {
            "import": {
                "types": "./build/es/tailwind/index.d.ts",
                "default": "./build/es/tailwind/index.js"
            },
            "require": {
                "types": "./build/cjs/tailwind/index.d.cts",
                "default": "./build/cjs/tailwind/index.cjs"
            }
        },
        "./hooks": {
            "import": {
                "types": "./build/es/hooks/index.d.ts",
                "default": "./build/es/hooks/index.js"
            },
            "require": {
                "types": "./build/cjs/hooks/index.d.cts",
                "default": "./build/cjs/hooks/index.cjs"
            }
        },
        "./utilities": {
            "import": {
                "types": "./build/es/utilities/index.d.ts",
                "default": "./build/es/utilities/index.js"
            },
            "require": {
                "types": "./build/cjs/utilities/index.d.cts",
                "default": "./build/cjs/utilities/index.cjs"
            }
        },
        "./*": {
            "import": {
                "types": "./build/es/components/*/index.d.ts",
                "default": "./build/es/components/*/index.js"
            },
            "require": {
                "types": "./build/cjs/components/*/index.d.cts",
                "default": "./build/cjs/components/*/index.cjs"
            }
        }
    },
    "scripts": {
        "generate:tokens": "tsx ./src/tokens/style-dictionary/build.ts",
        "build": "pnpm generate:tokens && pnpm run /compile:*/",
        "dev": "babel --out-dir=. dev-server.mjs && node dev-server.js",
        "compile:style": "node build-styles.mjs",
        "compile:scripts": "vite build --config vite.build.config.mjs",
        "test": "vitest --config vite.test.config.mjs",
        "figma:test": "figma connect publish --dry-run",
        "figma:publish": "figma connect publish"
    },
    "dependencies": {
        "downshift": "^7.6.2",
        "match-sorter": "^6.3.4"
    },
    "optionalDependencies": {
        "@floating-ui/react": "0.24.1 - 0.27",
        "@react-aria/toast": "3.0.0-beta.18",
        "@react-stately/toast": "3.0.0-beta.7",
        "react-a11y-dialog": "^6.2.0",
        "tailwindcss": "^3.4.17"
    },
    "devDependencies": {
        "@babel/cli": "^7.28.6",
        "@babel/preset-react": "^7.27.1",
        "@figma/code-connect": "^1.3.8",
        "@rollup/plugin-terser": "^0.4.4",
        "@types/react": "18.3.1",
        "@vitejs/plugin-react": "^4.7.0",
        "@vitejs/plugin-react-swc": "^3.11.0",
        "autoprefixer": "^10.4.21",
        "change-case": "^5.4.4",
        "cssnano": "^7.1.0",
        "cssnano-preset-lite": "^4.0.4",
        "dayjs": "^1.11.19",
        "glob": "^13.0.0",
        "ink": "^5.1.0",
        "ink-select-input": "^6.0.0",
        "jsdom": "^26.1.0",
        "nanoid": "^5.1.5",
        "postcss": "^8.5.6",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-hook-form": "^7.62.0",
        "react-is": "^18.3.1",
        "rollup-plugin-node-externals": "^8.0.1",
        "rollup-plugin-visualizer": "^6.0.3",
        "sass-embedded": "^1.90.0",
        "style-dictionary": "^5.0.1",
        "tailwindcss": "^3.4.17",
        "tsx": "^4.20.6",
        "vite": "^7.1.2",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^3.2.4",
        "vitest-axe": "^0.1.0"
    },
    "peerDependencies": {
        "@types/react": "^18.3.1 || ^19.0.0",
        "react": "^18.3.1 || ^19.0.0",
        "react-dom": "^18.3.1 || ^19.0.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/fremtind/jokul.git"
    },
    "bugs": {
        "url": "https://github.com/fremtind/jokul/issues"
    },
    "babel": {
        "presets": ["@babel/preset-react"]
    },
    "gitHead": "2728cf20df66dd1c647cdffb49aab5365433abdb"
}
